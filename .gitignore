# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# Python packaging / virtual environments
venv/
env/
*.egg-info/
*.eggs/
build/
dist/
*.whl
pip-wheel-metadata/

# ROS / catkin / colcon build products
devel/
install/
log/
.catkin_tools/
catkin_ws/
ros1/build/
ros1/devel/
ros1/install/
ros2/build/
ros2/install/
ros2/log/

# Experiment outputs and logs
wandb/
outputs/
logs/
runs/
checkpoints/
ckpts/
models/
videos/
quick-demos/eval_outputs/
isaac-training/outputs/
isaac-training/training/scripts/outputs/
isaac-training/training/scripts/wandb/

# Large model artifacts are ignored by default.
# Curated checkpoint baselines that are already tracked remain versioned.
*.pt
*.pth
*.ckpt
*.onnx

# Hydra / W&B nested outputs
*/outputs/*/.hydra/
*/wandb/
*/wandb/*/files/
*/wandb/*/*.wandb

# Isaac / third-party generated artifacts
isaac-training/third_party/orbit/_isaac_sim
isaac-training/third_party/rl/torchrl/version.py
isaac-training/third_party/tensordict/tensordict/version.py
isaac-training/third_party/warp/_build/
isaac-training/nv_shadercache/
**/nv_shadercache/
*/tensordict/version.py
*/warp/_build/
*/warp/warp/native/*.o

# Compiled binaries / libraries
*.so
*.o

# Local configuration
.env
.env.local
.env.*.local
docker-compose.override.yml

# IDE / OS
.vscode/
.idea/
*.idea/
*.ipr
*.iws
*.iml
out/
.DS_Store

# Temporary files
*.swp
*.swo
*~
*.bak
*.bak_*
*.tmp

# Legacy README demo GIFs should not be regenerated in this replication fork.
media/
